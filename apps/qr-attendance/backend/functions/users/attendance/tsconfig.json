{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noEmitOnError": false,
    "noEmit": false,
    "baseUrl": "./",
    "paths": {
      "../../../shared/db/connection": ["./shared/db/connection.d.ts"],
      "../../../shared/db/secrets": ["./shared/db/secrets.d.ts"],
      "../../../shared/utils/response": ["./shared/utils/response.d.ts"]
    }
  },
  "include": ["*.ts", "../../../shared/**/*.ts"],
  "exclude": ["node_modules", "../../../shared/**/*.js"]
}
